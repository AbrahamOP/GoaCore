# ============================================================================
#  GoaCore — exemple de configuration
#  Copier en .env puis remplir AU MINIMUM les variables OBLIGATOIRES ci-dessous.
#    cp .env.example .env
#  Tout le reste est OPTIONNEL au démarrage et se configure depuis l'interface
#  web (panneaux de connexion Proxmox / Wazuh / IA / Discord, assistant backup).
#  Précédence de configuration : valeur enregistrée en base > variable d'env > non configuré.
# ============================================================================

# ----------------------------------------------------------------------------
#  OBLIGATOIRE — l'application refuse de démarrer sans ces valeurs
# ----------------------------------------------------------------------------

# Clé secrète de session. Sert AUSSI à dériver le chiffrement AES-256-GCM des
# secrets stockés en base (token Proxmox, clés SSH, etc.).
# L'app REFUSE de démarrer si elle est vide, trop courte (< 32 caractères) ou
# égale à un placeholder connu. Générez une valeur forte :
#     openssl rand -hex 32
SESSION_SECRET=

# Identifiants MySQL. Choisissez des mots de passe FORTS (ne laissez pas de
# valeurs triviales). Le conteneur MySQL est initialisé avec ces valeurs au
# tout premier démarrage uniquement.
#     openssl rand -base64 24
DB_USER=goacloud
DB_PASSWORD=
DB_ROOT_PASSWORD=
DB_NAME=goacloud

# ----------------------------------------------------------------------------
#  OPTIONNEL — serveur / TLS (defaults sains, à ne modifier qu'au besoin)
# ----------------------------------------------------------------------------

# Cookies de session marqués Secure (HTTPS). Laisser "true" en production.
# COOKIE_SECURE=true

# Désactive la vérification du certificat TLS pour les appels SORTANTS vers
# Proxmox / Wazuh (utile si ces services ont un certificat auto-signé).
# À utiliser en connaissance de cause.
SKIP_TLS_VERIFY=false

# ----------------------------------------------------------------------------
#  OPTIONNEL — Proxmox (configurable depuis l'UI : Paramètres > Connexions)
# ----------------------------------------------------------------------------
# Laissez vide pour configurer entièrement depuis l'interface après /setup.
PROXMOX_URL=https://your-proxmox.example:8006
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=your-token-id
PROXMOX_TOKEN_SECRET=your-token-secret
# Stockage et bridge utilisés à la création de VM/CT. Laisser VIDE pour
# auto-détection via l'API Proxmox (1er stockage actif images/rootdir, 1er bridge).
PROXMOX_STORAGE=
PROXMOX_BRIDGE=

# ----------------------------------------------------------------------------
#  OPTIONNEL — Wazuh SIEM (configurable depuis l'UI)
# ----------------------------------------------------------------------------
WAZUH_API_URL=https://your-wazuh.example:55000
WAZUH_USER=wazuh-wui
WAZUH_PASSWORD=your-wazuh-password
# Indexer (port 9200) — requis pour les vulnérabilités/CVE et la recherche d'alertes.
WAZUH_INDEXER_URL=https://your-wazuh.example:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=your-indexer-password

# ----------------------------------------------------------------------------
#  OPTIONNEL — IA / enrichissement SOAR (configurable depuis l'UI)
# ----------------------------------------------------------------------------
# Fournisseur d'enrichissement des alertes : "ollama" (auto-hébergé) ou "openai".
AI_PROVIDER=ollama
# URL de l'endpoint (ex. Ollama : http://your-ollama.example:11434).
AI_URL=
# Clé API — requise uniquement pour le fournisseur OpenAI.
AI_API_KEY=
# Modèle à utiliser (ex. Ollama : qwen2.5:3b ; OpenAI : gpt-4o-mini).
AI_MODEL=
# Cibler un endpoint compatible OpenAI auto-hébergé (sinon API OpenAI publique).
OPENAI_BASE_URL=https://api.openai.com/v1

# ----------------------------------------------------------------------------
#  OPTIONNEL — Discord (configurable depuis l'UI)
# ----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id
# Canal dédié aux alertes d'authentification (fallback : DISCORD_CHANNEL_ID).
DISCORD_AUTH_CHANNEL_ID=your-auth-channel-id
# Canal dédié aux notifications Ansible (fallback : DISCORD_CHANNEL_ID).
DISCORD_ANSIBLE_CHANNEL_ID=your-ansible-channel-id

# ----------------------------------------------------------------------------
#  OPTIONNEL — Ansible : utilisateur SSH suggéré par défaut dans le formulaire
#  de planification. Laissez vide (recommandé) pour forcer l'admin à choisir un
#  utilisateur non-root : le login root est désactivé sur le parc (PermitRootLogin=no).
#  L'élévation root se fait via l'option « become » (sudo) du planificateur.
# ----------------------------------------------------------------------------
ANSIBLE_DEFAULT_REMOTE_USER=

# ----------------------------------------------------------------------------
#  OPTIONNEL / AVANCÉ — canal GoaBackup (test de restauration)
#  Préférez l'assistant in-app (Backup > Canal) qui génère la clé SSH, fournit
#  la commande d'installation root et vérifie le canal de bout en bout.
#  Les variables ci-dessous ne sont à renseigner que pour un câblage manuel ;
#  la plupart sont aussi paramétrables depuis l'UI (précédence base > env).
# ----------------------------------------------------------------------------
# Hôte/utilisateur SSH du helper read-only sur le Proxmox (forced-command).
# GOABACKUP_SSH_HOST=your-proxmox.example
# GOABACKUP_SSH_USER=goabackup
# GOABACKUP_SSH_KEY_FILE=/app/secrets/goabackup_key
# Isolation de la sandbox de test de restauration (cul-de-sac réseau).
# GOABACKUP_SANDBOX_VLAN=99
# GOABACKUP_SANDBOX_BRIDGE=vmbr1
# Stockages Proxmox utilisés par les tests de restauration.
# GOABACKUP_RESTORE_STORAGE=
# GOABACKUP_DEFAULT_STORAGE=local
# Garde-fous disque avant un test de restauration.
# GOABACKUP_DISK_CEILING_PCT=85
# GOABACKUP_MIN_LOCAL_AVAIL_GIB=5
# Rotation planifiée des tests de restauration (heure locale 0-23).
# GOABACKUP_TEST_ROTATION_ENABLED=false
# GOABACKUP_TEST_HOUR=4

# DNS optionnel pour le health-check des applications. Laissez vide pour le
# comportement Docker par défaut. Renseignez l'IP de votre resolver interne si
# vos services utilisent des domaines internes (DNS split-horizon) et
# apparaissent "hors ligne" à tort dans le dashboard.
GOACORE_HEALTHCHECK_DNS=
