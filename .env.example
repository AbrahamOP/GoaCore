# Database Config
DB_USER=goacloud
DB_PASS=secret
DB_ROOT_PASSWORD=root_secret
DB_NAME=goacloud

# Proxmox Config
PROXMOX_URL=https://your-proxmox-ip:8006
PROXMOX_TOKEN_ID=your-token-id
PROXMOX_TOKEN_SECRET=your-token-secret
PROXMOX_NODE=your-node-name

# Wazuh Config
WAZUH_API_URL=https://your-wazuh-ip:55000
WAZUH_USER=wazuh-wui
WAZUH_PASSWORD=your-wazuh-password

# Wazuh Indexer Config (Advanced - Port 9200)
# Nécessite que le port 9200 soit ouvert sur le serveur Wazuh
WAZUH_INDEXER_URL=https://your-wazuh-ip:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=your-indexer-password

# Discord Config
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id
# Canal dédié aux alertes d'authentification (optionnel, fallback sur DISCORD_CHANNEL_ID)
DISCORD_AUTH_CHANNEL_ID=your-auth-channel-id

# AI Enrichment Config (Optional)
AI_PROVIDER=ollama # or openai
AI_URL=http://your-ollama-host:11434
AI_API_KEY= # Required for OpenAI
AI_MODEL=mistral

# Sécurité TLS
# Mettre à "true" uniquement si Proxmox/Wazuh utilisent des certificats auto-signés
SKIP_TLS_VERIFY=false

# Clé secrète de session (CHANGEZ ABSOLUMENT cette valeur en production !)
SESSION_SECRET=change-me-to-a-long-random-secret
