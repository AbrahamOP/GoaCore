# ============================================================================
# GoaCore — configuration d'installation. Copiez ce fichier en « .env » à côté
# du docker-compose.yml, puis renseignez au minimum les valeurs REQUISES.
#   cp .env.example .env
# ============================================================================

# --- Version de l'image à déployer (latest = dernière publiée) ---
GOACORE_TAG=latest

# ============================================================================
# REQUIS
# ============================================================================

# Base de données MySQL (créée automatiquement par le conteneur db).
DB_NAME=goacore
DB_USER=goacore
DB_PASSWORD=change-me-mot-de-passe-fort
DB_ROOT_PASSWORD=change-me-root-mot-de-passe-fort

# Clé de signature des sessions — OBLIGATOIRE, 32+ octets aléatoires.
# Générez-la avec :  openssl rand -hex 32
SESSION_SECRET=change-me-openssl-rand-hex-32

# Cookies sécurisés (HTTPS). Laissez true en production.
COOKIE_SECURE=true
# Mettre true UNIQUEMENT si vos services internes ont des certificats auto-signés.
SKIP_TLS_VERIFY=false

# ============================================================================
# OPTIONNEL — tout ceci se configure aussi depuis l'interface (menu « Connexions »).
# Laissez vide pour commencer ; GoaCore vous guidera.
# ============================================================================

# --- Proxmox VE ---
PROXMOX_URL=
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_STORAGE=
PROXMOX_BRIDGE=

# --- Wazuh (SIEM) ---
WAZUH_API_URL=
WAZUH_USER=
WAZUH_PASSWORD=
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=

# --- Discord (notifications) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_AUTH_CHANNEL_ID=
DISCORD_ANSIBLE_CHANNEL_ID=

# --- IA / enrichissement SOAR ---
AI_PROVIDER=
AI_URL=
AI_API_KEY=
AI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
